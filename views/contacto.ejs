<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="flex flex-col min-h-screen">

<nav class="flex justify-between items-center p-6 bg-white shadow-sm">
    <div class="font-bold text-2xl text-teal-600"><%= nombreClinica %></div>
    <div class="space-x-6 font-semibold text-slate-600">
        <a href="/" class="hover:text-teal-600">Inicio</a>
        <a href="/servicios" class="hover:text-teal-600">Servicios</a>
        <a href="/contacto" class="text-teal-600">Contacto</a>
    </div>
</nav>

<main class="flex-grow">
    <!-- Sección 1: Intro Contacto -->
    <section class="section-container text-center pb-8">
        <h1 class="text-4xl font-bold mb-4"><%= heroMessage %></h1>
        <p class="text-slate-600 text-lg"><%= descripcion %></p>
    </section>

    <!-- Sección 2: Información de Contacto -->
    <section class="section-container flex flex-col md:flex-row gap-12 items-center">
        <div class="w-full md:w-1/2 bg-white p-8 rounded-2xl shadow-lg">
            <div class="space-y-6">
                <div>
                    <h4 class="text-xs uppercase tracking-widest text-teal-600 font-bold mb-1">Teléfono</h4>
                    <p class="text-xl font-semibold"><%= infoContacto.telefono %></p>
                </div>
                <div>
                    <h4 class="text-xs uppercase tracking-widest text-teal-600 font-bold mb-1">Email</h4>
                    <p class="text-xl font-semibold"><%= infoContacto.email %></p>
                </div>
                <div>
                    <h4 class="text-xs uppercase tracking-widest text-teal-600 font-bold mb-1">Ubicación</h4>
                    <p class="text-xl font-semibold"><%= infoContacto.direccion %></p>
                </div>
            </div>
        </div>
        <div class="w-full md:w-1/2">
            <div class="bg-teal-50 p-8 rounded-2xl border border-teal-100">
                <h3 class="text-2xl font-bold mb-4 italic">Horarios de Atención</h3>
                <ul class="text-slate-600 space-y-2">
                    <li><strong>Lunes a Viernes:</strong> 09:00 - 20:00</li>
                    <li><strong>Sábados:</strong> 10:00 - 14:00</li>
                    <li class="text-teal-600 font-bold">Urgencias: 24/7</li>
                </ul>
            </div>
        </div>
    </section>
</main>

<footer class="p-8 border-t border-slate-200 text-center text-slate-500 text-sm">
    <p>&copy; <%= new Date().getFullYear() %> <%= nombreClinica %>. Todos los derechos reservados.</p>
</footer>

</body>
</html>