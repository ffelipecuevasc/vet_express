<!-- views/duenos.ejs -->
<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
</head>
<body class="flex flex-col min-h-screen">
<%- include('partials/navbar') %>

<main class="flex-grow">
    <section class="section-container text-center pb-0">
        <h1 class="text-4xl font-bold mb-4 text-teal-600">Dueños</h1>
        <p class="text-slate-600 text-lg">
            Bienvenido/a, <strong class="text-teal-700"><%= usuario.nombre %></strong>. Este es el listado de dueños registrados en el sistema.
        </p>
    </section>

    <section class="section-container">

        <!-- Botón "Agregar dueño": apunta a la futura ruta de creación (Fase 7) -->
        <div class="flex justify-end mb-6">
            <a href="/duenos/crear"
               class="inline-block bg-teal-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-teal-700 transition shadow-lg shadow-teal-100">
                + Agregar dueño
            </a>
        </div>

        <% if (listaDuenos.length === 0) { %>
            <!-- ESTADO VACÍO: todavía no hay ningún dueño registrado -->
            <div class="bg-white p-10 rounded-2xl shadow-sm border border-slate-100 text-center">
                <p class="text-2xl mb-2">👤</p>
                <p class="text-slate-700 font-semibold text-lg mb-1">Todavía no hay dueños registrados.</p>
                <p class="text-slate-400 text-sm mb-6">Registra a tu primer dueño para comenzar a asociar sus datos de contacto en VetCare Pro.</p>
                <a href="/duenos/crear"
                   class="inline-block bg-teal-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-teal-700 transition">
                    Registrar primer dueño
                </a>
            </div>
        <% } else { %>
            <!-- TABLA DE LISTADO: recorre listaDuenos, ordenada por id DESC desde el controlador -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                    <tr class="border-b border-slate-100 text-xs uppercase tracking-widest text-slate-400">
                        <th class="px-6 py-4 font-bold">Nombre</th>
                        <th class="px-6 py-4 font-bold">Email</th>
                        <th class="px-6 py-4 font-bold">Teléfono</th>
                        <th class="px-6 py-4 font-bold">Dirección</th>
                        <th class="px-6 py-4 font-bold">Fecha de Registro</th>
                        <th class="px-6 py-4 font-bold text-right">Acciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    <% listaDuenos.forEach(dueno => { %>
                        <tr class="border-b border-slate-50 last:border-0 hover:bg-teal-50/50 transition">
                            <td class="px-6 py-4 font-semibold text-slate-800"><%= dueno.nombre %></td>
                            <td class="px-6 py-4 text-slate-600"><%= dueno.email %></td>
                            <td class="px-6 py-4 text-slate-600"><%= dueno.telefono %></td>
                            <td class="px-6 py-4 text-slate-600"><%= dueno.direccion || '—' %></td>
                            <td class="px-6 py-4 text-slate-600"><%= dueno.fechaRegistroFormateada %></td>
                            <td class="px-6 py-4 text-right whitespace-nowrap">
                                <!-- Columna reservada: los íconos de editar/eliminar llegan en las Fases 8 y 9 -->
                                <div class="flex items-center justify-end gap-3">
                                    <!-- Editar es un <a> -- navegar no cambia estado -->
                                    <a href="/duenos/<%= dueno.id %>/editar"
                                       class="text-teal-600 hover:text-teal-800 transition"
                                       title="Editar dueño">✏️</a>
                                    <!-- Eliminar es un <form method="POST"> propio de cada fila -->
                                    <form action="/duenos/<%= dueno.id %>/eliminar" method="POST" class="inline"
                                          onsubmit="return confirm('¿Seguro que deseas eliminar este dueño? Esta acción no se puede deshacer.');">
                                          <button type="submit" class="text-red-500 hover:text-red-700 transition" title="Eliminar dueño">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

    </section>
</main>

<%- include('partials/footer') %>
</body>
</html>